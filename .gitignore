# ---------------------------------------------------------------------------
# Recon Automation — root .gitignore
#
# NOTE: .env is intentionally NOT ignored (kept trackable per project decision —
# it holds no sensitive data). See the explicit un-ignore at the bottom.
# ---------------------------------------------------------------------------

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg

# Virtual environments
.venv/
venv/
env/
ENV/

# Test / coverage / type-check caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/

# --- Celery ---
celerybeat-schedule
celerybeat-schedule.*
celerybeat.pid

# --- Logs & runtime ---
logs/
*.log
*.pid

# --- Local storage / scan output ---
backend/storage/
storage/

# --- Node / frontend ---
node_modules/
.npm/
.pnpm-debug.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Vite / build output
frontend/dist/
dist/
.vite/

# --- Editor / OS ---
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# Keep .env tracked (overrides any ignore rules above / in subdirectories)
# ---------------------------------------------------------------------------
!.env
!**/.env

# ---------------------------------------------------------------------------
# Recon tool binaries (Phase: bundled tools/) — large, platform-specific Go/Rust
# binaries copied from PATH into tools/bin. Kept local-only; each dev provides
# their own via backend/tools/common/command_runner.py PATH resolution.
# The Python tool sources (LinkFinder, xnLinkFinder, SecretFinder) ARE tracked.
# ---------------------------------------------------------------------------
tools/bin/
